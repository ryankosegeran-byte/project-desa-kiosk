# Kiosk Desa - Environment Variables

# ==========================================
# Kiosk Local (.env di folder kiosk)
# ==========================================
KIOSK_DESA_ID=                    # UUID desa (wajib)
KIOSK_NAME=Kiosk Desa 1
KIOSK_LISTEN_ADDR=:8080
KIOSK_SERVER_URL=https://your-backend.serv00.net
KIOSK_API_KEY=                    # API key untuk sync
KIOSK_DB_PATH=data/kiosk.db
KIOSK_PRINT_CMD=SumatraPDF.exe
KIOSK_STATIC_DIR=web/dist
KIOSK_SYNC_INTERVAL=30

# ==========================================
# Server Online (.env di folder server)
# ==========================================
SERVER_LISTEN_ADDR=:3000
DATABASE_URL=postgres://user:pass@localhost:5432/kiosk_desa?sslmode=disable
JWT_SECRET=your-secret-key-min-32-chars-long
JWT_ACCESS_EXPIRY_MIN=60
JWT_REFRESH_EXPIRY_HR=168
CORS_ORIGINS=http://localhost:4321,https://your-dashboard.pages.dev
UPLOAD_DIR=uploads
