# Admin Dashboard (Vite) environment

# API backend (kosongkan utk same-origin di produksi)
VITE_API_URL=

# Jembatan RFID lokal (rfid-agent.exe) di laptop PIC untuk reader ACR122U (PC/SC).
# Browser tidak bisa akses USB reader langsung; agen lokal ini menjembatani via SSE.
# Default: http://localhost:8088
VITE_RFID_BRIDGE_URL=http://localhost:8088